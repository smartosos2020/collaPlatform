  "issuePolicy": {
    "feedbackProjectKey": "PILOTV2",
    "requiredFields": ["severity", "reporter", "module", "context", "reproductionSteps", "expected", "actual", "evidence", "owner"],
    "levels": [
      { "code": "P0", "definition": "Data loss, security breach, or pilot-wide outage", "responseMinutes": 15, "resolutionHours": 4 },
      { "code": "P1", "definition": "Core scenario blocked for one or more participants with no workaround", "responseMinutes": 30, "resolutionHours": 8 },
      { "code": "P2", "definition": "Scenario degraded but a safe workaround exists", "responseMinutes": 240, "resolutionHours": 48 },
      { "code": "P3", "definition": "Minor usability, copy, or improvement request", "responseMinutes": 1440, "resolutionHours": 120 }
    ],
    "stopConditions": ["Any confirmed P0", "Any uncontained permission leak", "Two open P1 issues affecting the same core scenario", "Restore or audit evidence becomes unavailable"]
  },
  "metrics": [
    { "code": "activeParticipantRate", "description": "Participants completing at least one assigned scenario", "operator": ">=", "threshold": 0.8, "source": "audit-and-scenario-log" },
    { "code": "scenarioCompletionRate", "description": "Assigned scenarios completed successfully", "operator": ">=", "threshold": 0.85, "source": "scenario-log" },
    { "code": "criticalErrorCount", "description": "Open P0 or P1 issues", "operator": "=", "threshold": 0, "source": "feedback-project" },
    { "code": "blockedParticipantCount", "description": "Participants blocked for more than one business day", "operator": "=", "threshold": 0, "source": "daily-status" },
    { "code": "satisfactionScore", "description": "Average participant score from 1 to 5", "operator": ">=", "threshold": 3.5, "source": "end-survey" }
